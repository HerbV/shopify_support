# Vorlage – Werte eintragen und als Datei `env` speichern (env steht in .gitignore)

# MS SQL (Mitgliederdatenbank)
SQL_SERVER=192.168.0.0
SQL_DATABASE=DBNAME
SQL_USER=user
SQL_PASSWORD=
SQL_PORT=1433
SQL_DRIVER=ODBC Driver 18 for SQL Server

# Bubble API
BUBBLE_API_KEY=
BUBBLE_BASE_URL=https://example.bubbleapps.io/api/1.1
BUBBLE_DATATYPE=OG_Rechnungen

# Shopify Admin API (client_credentials)
SHOPIFY_SHOP=meinshop
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
